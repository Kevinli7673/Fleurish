# Supabase
# Project Settings > API in your Supabase dashboard
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side / edge functions ONLY, never ship in the client bundle
SUPABASE_SERVICE_ROLE_KEY=

# Brevo SMTP (auth verification emails) — Settings > SMTP & API > SMTP in Brevo
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=
SMTP_SENDER_NAME=Fleurish

# Plant.id
# https://web.plant.id -> get an API key
PLANT_ID_API_KEY=

# Trefle (pre-hackathon seeding script only, not used at runtime)
# https://trefle.io -> request a personal access token
TREFLE_API_TOKEN=

# Expo / EAS (only needed if you go beyond Expo Go, e.g. EAS Build)
EXPO_PUBLIC_APP_ENV=development